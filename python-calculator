num1 = 10
num2 = 5
op = "+"

if op == "+":
    result = num1 + num2
elif op == "-":
    result = num1 - num2
elif op == "*":
    result = num1 * num2
elif op == "/":
    if num2 != 0:
        result = num1 / num2
    else:
        print("Error: Division by zero")
        exit()
else:
    print("Invalid operator")
    exit()

print("Result:", result)
